# Copy this file to .env and fill in your key for whichever provider you use.
# You only need ONE key — pick Groq OR Gemini.

# Groq (https://console.groq.com) — free, no credit card required
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (https://aistudio.google.com/app/apikey) — free tier
GOOGLE_API_KEY=your_google_api_key_here
